DATABASE_URL=mysql+pymysql://pdnsadmin:password@localhost:3306/powerdnsadmin
PDNS_API_URL=http://127.0.0.1:8081
PDNS_API_KEY=your-pdns-api-key-here
SECRET_KEY=change-me-in-production
FLASK_ENV=development
FLASK_DEBUG=true

# Zet deze op `false` tijdens lokale dev (http://127.0.0.1:5000) zodat de
# browser de session cookie ook over niet-TLS verbindingen meestuurt.
# In productie achter Caddy (HTTPS) laat je beide op de default (`true`).
# SESSION_COOKIE_SECURE=false
# REMEMBER_COOKIE_SECURE=false

# Production only (used by docker-compose.yml + Caddyfile)
DOMAIN=proxy.example.com
